---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookDemoButton from '../components/BookDemoButton.astro';

const categories = [
  {
    title: "AI Coding & Vibe Coding Tools",
    integrations: [
      { name: "Cursor", logo: "https://upload.wikimedia.org/wikipedia/commons/4/42/Cursor_logo.svg" },
      { name: "Replit", logo: "https://upload.wikimedia.org/wikipedia/commons/7/78/New_Replit_Logo.svg" },
      { name: "Lovable", logo: "https://lovable.dev/img/logo/lovable-logo-icon.svg" },
      { name: "GitHub Copilot", logo: "https://www.vectorlogo.zone/logos/github_copilot/github_copilot-icon.svg" },
      { name: "Codeium", logo: "https://static.cdnlogo.com/logos/c/54/codeium.svg" },
    ]
  },
  {
    title: "Source Control",
    integrations: [
      { name: "GitHub", logo: "https://www.vectorlogo.zone/logos/github/github-icon.svg" },
      { name: "GitLab", logo: "https://www.vectorlogo.zone/logos/gitlab/gitlab-icon.svg" },
      { name: "Bitbucket", logo: "https://www.vectorlogo.zone/logos/bitbucket/bitbucket-icon.svg" },
    ]
  },
  {
    title: "CI/CD",
    integrations: [
      { name: "GitHub Actions", logo: "https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/githubactions.svg" },
      { name: "GitLab CI/CD", logo: "https://www.vectorlogo.zone/logos/gitlab/gitlab-icon.svg" },
      { name: "CircleCI", logo: "https://www.vectorlogo.zone/logos/circleci/circleci-icon.svg" },
      { name: "Buildkite", logo: "https://www.vectorlogo.zone/logos/buildkite/buildkite-icon.svg" },
      { name: "Jenkins", logo: "https://www.vectorlogo.zone/logos/jenkins/jenkins-icon.svg" },
    ]
  },
  {
    title: "Cloud & Runtime Platforms",
    integrations: [
      { name: "AWS", logo: "https://upload.wikimedia.org/wikipedia/commons/9/93/Amazon_Web_Services_Logo.svg" },
      { name: "Google Cloud Platform", logo: "https://www.vectorlogo.zone/logos/google_cloud/google_cloud-icon.svg" },
      { name: "Microsoft Azure", logo: "https://upload.wikimedia.org/wikipedia/commons/f/fa/Microsoft_Azure.svg" },
      { name: "Kubernetes", logo: "https://www.vectorlogo.zone/logos/kubernetes/kubernetes-icon.svg" },
      { name: "Vercel", logo: "https://www.vectorlogo.zone/logos/vercel/vercel-icon.svg" },
    ]
  },
  {
    title: "Observability & Logs",
    integrations: [
      { name: "Datadog", logo: "https://www.vectorlogo.zone/logos/datadoghq/datadoghq-icon.svg" },
      { name: "New Relic", logo: "https://www.vectorlogo.zone/logos/newrelic/newrelic-icon.svg" },
      { name: "Grafana", logo: "https://www.vectorlogo.zone/logos/grafana/grafana-icon.svg" },
      { name: "Splunk", logo: "https://www.vectorlogo.zone/logos/splunk/splunk-icon.svg" },
      { name: "Elastic", logo: "https://www.vectorlogo.zone/logos/elastic/elastic-icon.svg" },
    ]
  },
  {
    title: "Error Monitoring",
    integrations: [
      { name: "Sentry", logo: "https://www.vectorlogo.zone/logos/sentryio/sentryio-icon.svg" },
      { name: "Bugsnag", logo: "https://www.vectorlogo.zone/logos/bugsnag/bugsnag-icon.svg" },
      { name: "Rollbar", logo: "https://www.vectorlogo.zone/logos/rollbar/rollbar-icon.svg" },
    ]
  }
];
---

<BaseLayout
  title="Integrations | Softprobe"
  description="Softprobe integrates with the tools you already use, from AI coding assistants to production observability platforms."
>
  <div class="integrations-page">
    <!-- Hero Section -->
    <header class="hero">
      <div class="section-container">
        <h1 class="hero-title">Integrations</h1>
        <p class="hero-lead">Softprobe works with the tools you already use. And we're always adding more.</p>
        <div class="hero-actions">
          <BookDemoButton />
        </div>
      </div>
    </header>

    <!-- Integrations Grid -->
    <section class="integrations-content">
      <div class="section-container">
        {categories.map((category) => (
          <div class="category-section">
            <h2 class="category-title">{category.title}</h2>
            <div class="integrations-grid">
              {category.integrations.map((item) => (
                <div class="integration-card card">
                  <div class="logo-wrapper">
                    <img src={item.logo} alt={`${item.name} logo`} loading="lazy" />
                  </div>
                  <span class="integration-name">{item.name}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="cta-section">
      <div class="section-container">
        <div class="cta-card">
          <h2 class="cta-title">Need another integration?</h2>
          <div class="cta-actions">
            <a href="mailto:hello@softprobe.dev" class="btn btn-secondary glass">Request Integration</a>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .integrations-page {
    width: 100%;
  }

  /* Hero */
  .hero { 
    padding-top: 120px; 
    padding-bottom: 60px; 
    text-align: center; 
    background: linear-gradient(to bottom, #fff, var(--box-bg)); 
  }
  .hero-title { 
    font-size: clamp(2.5rem, 5vw, 4rem); 
    margin-bottom: 24px; 
  }
  .hero-lead { 
    font-size: 1.25rem; 
    color: var(--text-muted); 
    max-width: 800px; 
    margin: 0 auto 40px; 
  }
  .hero-actions { 
    display: flex; 
    justify-content: center; 
  }

  /* Content */
  .integrations-content {
    padding: 40px 0 80px;
  }

  .category-section {
    margin-bottom: 80px;
  }
  .category-section:last-child {
    margin-bottom: 0;
  }

  .category-title {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text-color);
    letter-spacing: -0.02em;
    margin-bottom: 32px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--box-border);
  }

  .integrations-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 24px;
  }

  .integration-card {
    padding: 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 20px;
    text-align: center;
  }

  .logo-wrapper {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo-wrapper img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .integration-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-color);
  }

  /* CTA Override */
  .cta-section { padding: 80px 0 120px; }
  .cta-card { 
    background: var(--text-color); 
    border-radius: 32px; 
    padding: 80px 40px; 
    text-align: center; 
    position: relative; 
    overflow: hidden; 
    box-shadow: 0 40px 100px rgba(15, 23, 42, 0.2);
  }
  .cta-card::before {
    content: "";
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle at center, rgba(139, 92, 246, 0.15) 0%, transparent 50%);
    pointer-events: none;
  }
  .cta-title { color: #fff; font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 16px; position: relative; z-index: 1; }
  .cta-lead { color: rgba(255, 255, 255, 0.7); font-size: 1.1rem; margin-bottom: 40px; position: relative; z-index: 1; max-width: 600px; margin-left: auto; margin-right: auto; }
  .cta-actions { display: flex; gap: 20px; justify-content: center; position: relative; z-index: 1; }
  .glass { background: rgba(255,255,255,0.1) !important; color: #fff !important; border-color: rgba(255,255,255,0.2) !important; }
  .glass:hover { background: rgba(255,255,255,0.2) !important; }

  @media (max-width: 900px) {
    .integrations-grid {
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    }
    .cta-card { padding: 60px 24px; }
  }

  @media (max-width: 640px) {
    .integrations-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
    .integration-card {
      padding: 24px 16px;
    }
    .logo-wrapper {
      width: 48px;
      height: 48px;
    }
  }
</style>
