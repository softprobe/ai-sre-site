---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookDemoButton from '../components/BookDemoButton.astro';
import CustomerLogos from '../components/CustomerLogos.astro';
---

<BaseLayout
  title="AI Regression Testing from Live Traffic | Softprobe"
  description="Softprobe is the AI-powered shadow testing layer that turns every production request into a regression test before it is ever deployed."
  canonical="https://softprobe.ai/"
>
  <!-- HERO SECTION -->
  <header class="hero">
    <div class="section-container hero-grid">
      <div class="hero-content">
        <h1 class="hero-title"><span data-i18n="home.hero.title1">AI Writes Code.</span><br /><span class="text-primary hero-title-line2" data-i18n="home.hero.title2">Softprobe Validates It.</span></h1>
        <p class="hero-lead" data-i18n="home.hero.lead">AI made development 10× faster. It made breaking things 10× faster too. Softprobe is the AI-powered shadow testing layer that catches bugs before they're ever deployed.</p>
        
        <div class="hero-actions">
          <BookDemoButton />
          <a href="/regression-how-it-works" class="btn btn-secondary" data-i18n="home.hero.howItWorks">How it works</a>
        </div>

        <div class="hero-benefits">
          <div class="benefit-item">
            <span class="benefit-icon">✓</span>
            <span data-i18n="home.hero.benefit1">Never write a regression test again.</span>
          </div>
          <div class="benefit-item">
            <span class="benefit-icon">✓</span>
            <span data-i18n="home.hero.benefit2">Generate millions of tests instantly.</span>
          </div>
          <div class="benefit-item">
            <span class="benefit-icon">✓</span>
            <span data-i18n="home.hero.benefit3">100% coverage of real user behavior.</span>
          </div>
        </div>
      </div>

      <div class="hero-visual">
        <div class="visual-card architecture-visual">
          <div class="architecture-diagram" aria-hidden="true">
            <svg viewBox="0 0 400 300" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Nodes -->
              <rect x="20" y="120" width="80" height="60" rx="12" fill="white" stroke="var(--box-border)" stroke-width="2"/>
              <text x="60" y="155" text-anchor="middle" font-size="12" font-weight="700" fill="var(--text-color)">Production</text>
              
              <rect x="160" y="110" width="80" height="80" rx="16" fill="var(--primary-color)" />
              <text x="200" y="155" text-anchor="middle" font-size="11" font-weight="800" fill="white">SOFTPROBE</text>
              
              <rect x="300" y="60" width="80" height="60" rx="12" fill="white" stroke="var(--box-border)" stroke-width="2"/>
              <text x="340" y="95" text-anchor="middle" font-size="11" font-weight="700" fill="var(--text-color)">Staging</text>
              
              <rect x="300" y="180" width="80" height="60" rx="12" fill="white" stroke="var(--box-border)" stroke-width="2"/>
              <text x="340" y="210" text-anchor="middle" font-size="10" font-weight="700" fill="var(--text-color)">Shadow Tests</text>

              <!-- Connection Paths -->
              <path d="M100 150 H160" stroke="var(--box-border)" stroke-width="2" stroke-dasharray="4 4" />
              <path d="M240 150 Q270 150 270 120 V90 Q270 90 300 90" stroke="var(--box-border)" stroke-width="2" stroke-dasharray="4 4" />
              <path d="M240 150 Q270 150 270 180 V210 Q270 210 300 210" stroke="var(--box-border)" stroke-width="2" stroke-dasharray="4 4" />

              <!-- Animated Particles -->
              <circle r="4" fill="var(--primary-color)">
                <animateMotion dur="3s" repeatCount="indefinite" path="M100 150 H160" />
              </circle>
              <circle r="3" fill="var(--accent-color)">
                <animateMotion dur="4s" begin="1s" repeatCount="indefinite" path="M240 150 Q270 150 270 120 V90 Q270 90 300 90" />
              </circle>
              <circle r="3" fill="var(--accent-color)">
                <animateMotion dur="4s" begin="1.5s" repeatCount="indefinite" path="M240 150 Q270 150 270 180 V210 Q270 210 300 210" />
              </circle>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- TRUSTED BY -->
  <section class="logos-section">
    <CustomerLogos />
  </section>

  <!-- PROBLEM SECTION -->
  <section class="section-alt">
    <div class="section-container">
      <div class="section-header">
        <span class="badge" data-i18n="home.problem.badge">The Problem</span>
        <h2 class="section-title" data-i18n="home.problem.title">The AI Coding Explosion</h2>
        <p class="section-lead" data-i18n="home.problem.lead">Every release now carries more hidden risk.</p>
      </div>

      <div class="bento-grid">
        <div class="bento-item bento-visual">
          <div class="visual-card chart-visual">
            <div class="chart-container" aria-hidden="true">
              <svg viewBox="0 0 500 340" fill="none" xmlns="http://www.w3.org/2000/svg" style="overflow: visible;">
                <defs>
                  <linearGradient id="risk-zone" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="var(--primary-color)" stop-opacity="0.35" />
                    <stop offset="100%" stop-color="var(--primary-color)" stop-opacity="0.0" />
                  </linearGradient>
                  
                  <linearGradient id="human-gradient" x1="0" y1="0" x2="1" y2="0">
                    <stop offset="0%" stop-color="#ddd6fe" />
                    <stop offset="100%" stop-color="#a78bfa" />
                  </linearGradient>

                  <linearGradient id="ai-gradient" x1="0" y1="0" x2="1" y2="0">
                    <stop offset="0%" stop-color="#c4b5fd" />
                    <stop offset="100%" stop-color="var(--primary-color)" />
                  </linearGradient>

                  <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
                    <feDropShadow dx="0" dy="8" stdDeviation="12" flood-color="var(--primary-color)" flood-opacity="0.25" />
                  </filter>
                  
                  <filter id="soft-glow" x="-20%" y="-20%" width="140%" height="140%">
                    <feDropShadow dx="0" dy="4" stdDeviation="6" flood-color="#475569" flood-opacity="0.1" />
                  </filter>
                </defs>

                <!-- Grid lines (horizontal only for minimal, modern feel) -->
                <path class="chart-grid" d="M 40 280 L 460 280" stroke="#f1f5f9" stroke-width="2" />
                <path class="chart-grid" d="M 40 200 L 460 200" stroke="#f1f5f9" stroke-width="2" />
                <path class="chart-grid" d="M 40 120 L 460 120" stroke="#f1f5f9" stroke-width="2" />
                <path class="chart-grid" d="M 40 40 L 460 40" stroke="#f1f5f9" stroke-width="2" />

                <!-- Risk Zone Area (fades in) -->
                <path class="chart-area-fill" d="M 40 280 C 220 280, 340 150, 460 30 L 460 240 L 40 280 Z" fill="url(#risk-zone)" />

                <!-- Human Written Tests Line -->
                <path class="draw-line-human" d="M 40 280 L 460 240" stroke="url(#human-gradient)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" filter="url(#soft-glow)" />
                
                <!-- AI Code Volume Line -->
                <path class="draw-line-ai" d="M 40 280 C 220 280, 340 150, 460 30" stroke="url(#ai-gradient)" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" filter="url(#glow)" />

                <!-- Data Points AI -->
                <g class="chart-points-ai">
                  <circle cx="460" cy="30" r="16" fill="var(--primary-color)" opacity="0.15" class="pulse-ring" />
                  <circle cx="460" cy="30" r="6" fill="#fff" stroke="var(--primary-color)" stroke-width="3" />
                </g>

                <!-- Data Points Human -->
                <circle class="chart-points-human" cx="460" cy="240" r="5" fill="#fff" stroke="#a78bfa" stroke-width="2.5" />

                <!-- Risk Label Box -->
                <g class="risk-label-group">
                  <rect x="220" y="105" width="140" height="34" rx="8" fill="#fff" stroke="var(--primary-color)" stroke-width="1.5" filter="url(#soft-glow)" />
                  <text x="290" y="127" font-size="12" font-weight="800" fill="var(--primary-color)" font-family="system-ui, -apple-system, sans-serif" text-anchor="middle">Test Coverage Gap</text>
                  <path d="M 290 139 L 290 205" stroke="var(--primary-color)" stroke-width="1.5" stroke-dasharray="4 4" opacity="0.5" />
                </g>

                <!-- Timeline Labels -->
                <text x="40" y="310" font-size="12" font-weight="600" fill="#94a3b8" font-family="system-ui, -apple-system, sans-serif">2023</text>
                <text x="250" y="310" font-size="12" font-weight="600" fill="#94a3b8" font-family="system-ui, -apple-system, sans-serif" text-anchor="middle">Today</text>
                <text x="460" y="310" font-size="12" font-weight="600" fill="#94a3b8" font-family="system-ui, -apple-system, sans-serif" text-anchor="end">2026</text>

                <!-- Series Labels -->
                <text x="440" y="25" font-size="13" font-weight="800" fill="#0f172a" font-family="system-ui, -apple-system, sans-serif" text-anchor="end">AI Code Volume</text>
                <text x="440" y="255" font-size="12" font-weight="700" fill="#a78bfa" font-family="system-ui, -apple-system, sans-serif" text-anchor="end">Manual Tests</text>
              </svg>
            </div>
          </div>
        </div>
        <div class="bento-item bento-content">
          <p class="highlight-text" data-i18n="home.problem.highlight">With AI, every commit changes more surface area.</p>
          <ul class="feature-list">
            <li>
              <strong data-i18n="home.problem.item1.title">Entire endpoints</strong>
              <p data-i18n="home.problem.item1.desc">Shipped in single commits with huge surface area.</p>
            </li>
            <li>
              <strong data-i18n="home.problem.item2.title">Massive refactors</strong>
              <p data-i18n="home.problem.item2.desc">Global changes that manual tests miss.</p>
            </li>
            <li>
              <strong data-i18n="home.problem.item3.title">Production-ready features</strong>
              <p data-i18n="home.problem.item3.desc">Released at a velocity QA teams can't match.</p>
            </li>
          </ul>
          <p class="problem-punch" data-i18n="home.problem.punch">AI can ship bugs faster than humans can test for them.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SOLUTION SECTION -->
  <section class="section">
    <div class="section-container">
      <div class="section-header">
        <span class="badge" data-i18n="home.solution.badge">The Solution</span>
        <h2 class="section-title" data-i18n="home.solution.title">AI-Powered Large Scale Regression Testing</h2>
        <p class="section-lead" data-i18n="home.solution.lead">Softprobe learns from live production traffic end to end—including all dependencies and exact environment states—and creates millions of test cases.</p>
        <div class="punch-tag" data-i18n="home.solution.punch">Every production request becomes a test. Instantly.</div>
      </div>

      <div class="comparison-table-wrap">
        <table class="comparison-table">
          <thead>
            <tr>
              <th data-i18n="home.solution.table.capability">Capability</th>
              <th data-i18n="home.solution.table.standard">Standard Testing</th>
              <th class="featured-col" data-i18n="home.solution.table.softprobe">SOFTPROBE AI</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td data-i18n="home.solution.table.row1.label">Test Code</td>
              <td data-i18n="home.solution.table.row1.standard">Manual + AI generated</td>
              <td class="featured-col">
                <div class="featured-col-item">
                  <span class="check-icon">✓</span>
                  <span data-i18n="home.solution.table.row1.sp">No Code</span>
                </div>
              </td>
            </tr>
            <tr>
              <td data-i18n="home.solution.table.row2.label">Data Source</td>
              <td data-i18n="home.solution.table.row2.standard">Manually Created Test Samples</td>
              <td class="featured-col">
                <div class="featured-col-item">
                  <span class="check-icon">✓</span>
                  <span data-i18n="home.solution.table.row2.sp">Real World Use Cases (100% Coverage)</span>
                </div>
              </td>
            </tr>
            <tr>
              <td data-i18n="home.solution.table.row3.label">Dependencies</td>
              <td data-i18n="home.solution.table.row3.standard">Manual Mocks</td>
              <td class="featured-col">
                <div class="featured-col-item">
                  <span class="check-icon">✓</span>
                  <span data-i18n="home.solution.table.row3.sp">Captured From Real Traffic &amp; Injected</span>
                </div>
              </td>
            </tr>
            <tr>
              <td data-i18n="home.solution.table.row4.label">Environment</td>
              <td data-i18n="home.solution.table.row4.standard">Test Environment</td>
              <td class="featured-col">
                <div class="featured-col-item">
                  <span class="check-icon">✓</span>
                  <span data-i18n="home.solution.table.row4.sp">Test Env that 100% Mirrors Production</span>
                </div>
              </td>
            </tr>
            <tr>
              <td data-i18n="home.solution.table.row5.label">Flaky Tests</td>
              <td data-i18n="home.solution.table.row5.standard">Difficult to Reproduce</td>
              <td class="featured-col">
                <div class="featured-col-item">
                  <span class="check-icon">✓</span>
                  <span data-i18n="home.solution.table.row5.sp">100% Reproducible</span>
                </div>
              </td>
            </tr>
            <tr>
              <td data-i18n="home.solution.table.row6.label">Canary Testing</td>
              <td data-i18n="home.solution.table.row6.standard">Impacts Real Users. Slows Releases.</td>
              <td class="featured-col">
                <div class="featured-col-item">
                  <span class="check-icon">✓</span>
                  <span data-i18n="home.solution.table.row6.sp">Zero User impact. Faster Releases.</span>
                </div>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section class="cta-section">
    <div class="section-container">
      <div class="cta-card">
        <h2 class="cta-title"><span data-i18n="home.cta.title1">Write code at AI speed.</span><br /><span data-i18n="home.cta.title2">Deploy with absolute confidence.</span></h2>
        <div class="cta-actions">
          <BookDemoButton />
          <a href="/contact" class="btn btn-secondary" data-i18n="home.cta.talkExpert">Talk to an expert</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .text-primary { color: var(--primary-color); }
  .hero { padding-top: 120px; padding-bottom: 48px; }
  .hero-grid { display: grid; grid-template-columns: 1.1fr 1fr; gap: 80px; align-items: center; }
  .hero-title { font-size: clamp(2.5rem, 5vw, 4.25rem); line-height: 1.15; margin-bottom: 32px; }
.hero-title-line2 { display: block; margin-top: 0.15em; }
  .hero-lead { font-size: 1.25rem; color: var(--text-muted); margin-bottom: 40px; max-width: 540px; }
  .hero-actions { display: flex; gap: 16px; margin-bottom: 48px; align-items: center; }
.hero-actions .btn { min-width: 160px; min-height: 44px; }
  .hero-benefits { display: grid; gap: 12px; }
  .benefit-item { display: flex; align-items: center; gap: 10px; font-weight: 600; color: var(--text-color); font-size: 0.95rem; }
  .benefit-icon { color: var(--primary-color); font-weight: 900; }

  .hero-visual, .bento-item.bento-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .visual-card { 
    background: transparent; 
    border: none; 
    padding: 24px; 
    aspect-ratio: 1;
    width: 100%;
    max-width: 520px;
    min-height: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
  }
  .visual-card.dark { background: var(--text-color); color: #fff; border: none; }
  .visual-placeholder-content p { font-size: 1.1rem; line-height: 1.5; color: inherit; }

  .logos-section { width: 100%; padding: 10px 0 80px; text-align: center; }

  .section-alt .section-container {
    background: transparent;
  }
  .section-header { margin-bottom: 20px; max-width: 800px; }
  .badge { 
    display: inline-block; 
    font-size: 0.75rem; 
    font-weight: 800; 
    text-transform: uppercase; 
    color: var(--primary-color); 
    margin-bottom: 16px; 
    letter-spacing: 0.1em;
  }
  .section-title { font-size: clamp(2rem, 4vw, 2.75rem); margin-bottom: 24px; }
  .section-lead { font-size: 1.2rem; color: var(--text-muted); margin-bottom: 0; }

  .bento-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; }
  .bento-grid.reverse { direction: rtl; }
  .bento-grid.reverse > * { direction: ltr; }
  .highlight-text { font-size: 1.5rem; font-weight: 800; color: var(--text-color); margin-bottom: 32px; }
  .feature-list { list-style: none; padding: 0; display: grid; gap: 24px; }
  .feature-list li { padding-left: 24px; border-left: 3px solid var(--primary-color); }
  .feature-list strong { display: block; font-size: 1.1rem; margin-bottom: 4px; }
  .feature-list p { margin: 0; font-size: 0.95rem; }
  .problem-punch { margin-top: 24px; font-weight: 800; font-size: 1.1rem; color: var(--text-color); }

  .punch-tag { display: inline-block; margin-top: 32px; font-weight: 800; font-size: 1.25rem; color: var(--text-color); border-bottom: 4px solid var(--primary-color); padding-bottom: 4px; }

  /* Visual Animations & Styles */
  .architecture-diagram, .chart-container {
    width: 100%;
    max-width: 500px;
    margin: 0 auto;
    overflow: visible;
  }
  
  .architecture-diagram svg, .chart-container svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .chart-area-fill {
    opacity: 0;
    animation: chartFadeIn 1.5s ease-out 1.2s forwards;
  }

  .draw-line-ai {
    stroke-dasharray: 1200;
    stroke-dashoffset: 1200;
    animation: chartDraw 2.2s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  .draw-line-human {
    stroke-dasharray: 1200;
    stroke-dashoffset: 1200;
    animation: chartDraw 2.2s cubic-bezier(0.4, 0, 0.2, 1) 0.3s forwards;
  }

  .chart-grid {
    opacity: 0;
    animation: chartFadeIn 1s ease-out forwards;
  }

  .chart-points-ai, .chart-points-human, .risk-label-group {
    opacity: 0;
    animation: chartFadeIn 1s ease-out 2s forwards;
  }

  .pulse-ring {
    transform-origin: 460px 30px;
    animation: pulseObj 2.5s infinite ease-out 2s;
  }

  @keyframes pulseObj {
    0% { transform: scale(0.8); opacity: 0.3; }
    50% { transform: scale(1.4); opacity: 0; }
    100% { transform: scale(0.8); opacity: 0; }
  }

  @keyframes chartFadeIn {
    to { opacity: 1; }
  }

  @keyframes chartDraw {
    to { stroke-dashoffset: 0; }
  }

  @keyframes chartShimmer {
    0% { stroke-dashoffset: 1000; }
    100% { stroke-dashoffset: -1000; }
  }

  /* Node styling within SVG */
  .architecture-diagram rect {
    transition: transform 0.3s ease;
  }
  
  .architecture-diagram svg:hover rect {
    transform: scale(1.02);
  }

  .comparison-table-wrap {
    overflow-x: auto;
    border: 1px solid var(--box-border);
    border-radius: 24px;
    background: #fff;
    box-shadow: 0 40px 100px rgba(15, 23, 42, 0.05);
  }
  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
    min-width: 800px;
    table-layout: fixed; /* Force consistent column widths */
  }
  .comparison-table th, .comparison-table td {
    padding: 16px 32px;
    border-bottom: 1px solid var(--line-color);
    vertical-align: middle;
  }
  .comparison-table th:not(:last-child), .comparison-table td:not(:last-child) {
    border-right: 1px solid var(--line-color);
  }
  .comparison-table th {
    font-size: 0.85rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    background: #f8fafc;
    padding: 20px 32px;
  }
  .comparison-table th:first-child { width: 20%; }
  .comparison-table th:nth-child(2),
  .comparison-table th:nth-child(3) { width: 40%; }

  .comparison-table td:first-child {
    font-weight: 700;
    color: var(--text-color);
  }
  .comparison-table td {
    font-size: 0.95rem;
    color: var(--text-muted);
  }
  .comparison-table .featured-col {
    background: #f8fafc;
    color: var(--text-color);
    font-weight: 400;
    border-left: 1px solid rgba(139, 92, 246, 0.2);
    border-right: 1px solid rgba(139, 92, 246, 0.2);
    border-bottom: 1px solid rgba(139, 92, 246, 0.2);
    position: relative;
    box-shadow: 10px 0 30px rgba(15, 23, 42, 0.03);
  }
  .comparison-table th.featured-col {
    background: var(--primary-color);
    color: #fff;
    font-weight: 900;
    border: none;
    box-shadow: 10px -10px 30px rgba(15, 23, 42, 0.05);
  }
  .featured-col-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }
  .check-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    background: var(--accent-color);
    color: #fff;
    border-radius: 50%;
    font-size: 0.7rem;
    flex-shrink: 0;
    margin-top: 2px; /* Adjusted for smaller font size */
  }
  .comparison-table tr:last-child td {
    border-bottom: none;
  }
  .comparison-table tr:last-child .featured-col {
    border-bottom: 1px solid rgba(139, 92, 246, 0.2);
  }
  .comparison-table tbody tr:hover td:not(.featured-col) {
    background: #fbfbfb;
  }
  .comparison-table tbody tr:hover .featured-col {
    background: #f1f5f9;
  }
  
  .cta-section { padding: 48px 0; }
  .cta-card { 
    background: transparent; 
    border: none; 
    padding: 80px 40px; 
    text-align: center; 
    position: relative; 
    max-width: var(--site-page-max-width);
    margin: 0 auto;
  }
  .cta-title { color: var(--text-color); font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 40px; position: relative; z-index: 1; }
  .cta-actions { display: flex; gap: 20px; justify-content: center; align-items: center; position: relative; z-index: 1; }
  .cta-actions .btn { min-width: 160px; min-height: 44px; }

  @media (max-width: 900px) {
    .hero-grid, .bento-grid, .compare-grid { grid-template-columns: 1fr; gap: 40px; }
    .hero { text-align: center; padding-top: 80px; }
    .hero-lead { margin-left: auto; margin-right: auto; }
    .hero-actions, .hero-benefits { justify-content: center; }
    .compare-card.featured { transform: none; }
    .cta-card { padding: 60px 24px; }
  }
</style>
