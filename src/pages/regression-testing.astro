---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookDemoButton from '../components/BookDemoButton.astro';
import CustomerLogos from '../components/CustomerLogos.astro';
---

<BaseLayout
  title="AI Regression Testing from Live Traffic | Softprobe"
  description="Softprobe is the AI-powered shadow testing layer that turns every production request into a regression test before it is ever deployed."
>
  <div class="rp">
    <!-- Hero: full-width, centered, no sidebar clutter -->
    <header class="rp-hero">
      <div class="rp-hero-bg" aria-hidden="true"></div>
      <div class="rp-hero-content">
        <span class="rp-hero-badge">AI-Powered Shadow Testing</span>
        <h1 class="rp-hero-title">AI writes code.<br />We make sure it works.</h1>
        <p class="rp-hero-sub">One sentence: every production request becomes a regression test. No test code to write.</p>
        <div class="rp-hero-pills">
          <span>No test code</span>
          <span>Live traffic → tests</span>
          <span>100% real behavior</span>
        </div>
        <div class="rp-hero-cta">
          <BookDemoButton />
          <a href="/regression-how-it-works" class="rp-btn rp-btn-ghost">How it works</a>
        </div>
      </div>
    </header>

    <section class="rp-trusted" aria-label="Trusted by">
      <CustomerLogos />
    </section>

    <!-- Problem: one line + 3 cards -->
    <section class="rp-block rp-block--light">
      <div class="rp-container">
        <span class="rp-label">The problem</span>
        <h2 class="rp-heading">The regression explosion</h2>
        <p class="rp-lead">AI ships endpoints, refactors, and features faster than humans can test.</p>
        <div class="rp-cards">
          <div class="rp-card">
            <div class="rp-card-icon" aria-hidden="true">1</div>
            <h3>Entire endpoints</h3>
            <p>One commit, huge surface area</p>
          </div>
          <div class="rp-card">
            <div class="rp-card-icon" aria-hidden="true">2</div>
            <h3>Massive refactors</h3>
            <p>More risk, same manual tests</p>
          </div>
          <div class="rp-card">
            <div class="rp-card-icon" aria-hidden="true">3</div>
            <h3>Production-ready features</h3>
            <p>Shipped before QA can scale</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Solution: headline + one line + comparison -->
    <section class="rp-block rp-block--white">
      <div class="rp-container">
        <span class="rp-label">The solution</span>
        <h2 class="rp-heading">Regression from live traffic</h2>
        <p class="rp-lead">Softprobe turns production traffic into millions of tests in your test env—dependencies and state included.</p>

        <div class="rp-compare">
          <div class="rp-compare-col rp-compare-col--old">
            <h3>Standard testing</h3>
            <ul>
              <li><em>Test code</em> Manual + AI written</li>
              <li><em>Data</em> Hand-made samples</li>
              <li><em>Dependencies</em> Manual mocks</li>
              <li><em>Flakiness</em> Hard to reproduce</li>
            </ul>
          </div>
          <div class="rp-compare-col rp-compare-col--new">
            <h3>Softprobe</h3>
            <ul>
              <li><em>Test code</em> None</li>
              <li><em>Data</em> Real traffic (100% coverage)</li>
              <li><em>Dependencies</em> Captured & injected</li>
              <li><em>Flakiness</em> 100% reproducible</li>
            </ul>
          </div>
        </div>

        <div class="rp-rca">
          <p><strong>Deterministic RCA.</strong> Canary tests impact users and slow releases. Softprobe runs in test—zero user impact, faster releases.</p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="rp-cta">
      <div class="rp-cta-inner">
        <h2>Ship at AI speed. Deploy with confidence.</h2>
        <div class="rp-cta-btns">
          <BookDemoButton />
          <a href="/regression-how-it-works" class="rp-btn rp-btn-ghost">How it works</a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .rp {
    width: 100%;
  }

  /* Hero: full bleed, centered, minimal */
  .rp-hero {
    position: relative;
    min-height: 72vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(80px, 12vw, 140px) 24px;
    text-align: center;
  }

  .rp-hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 50% at 50% 0%, rgba(139, 92, 246, 0.08) 0%, transparent 55%),
      radial-gradient(ellipse 60% 40% at 80% 60%, rgba(139, 92, 246, 0.05) 0%, transparent 50%);
    pointer-events: none;
  }

  .rp-hero-content {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
  }

  .rp-hero-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--primary-color);
    margin-bottom: 20px;
  }

  .rp-hero-title {
    font-size: clamp(2.75rem, 6vw, 4rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1.05;
    color: var(--text-color);
    margin: 0 0 24px;
  }

  .rp-hero-sub {
    font-size: 1.25rem;
    line-height: 1.5;
    color: #475569;
    margin: 0 0 32px;
    max-width: 42ch;
    margin-left: auto;
    margin-right: auto;
  }

  .rp-hero-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
    margin-bottom: 36px;
  }

  .rp-hero-pills span {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-color);
    background: #fff;
    border: 1px solid #e2e8f0;
    padding: 8px 16px;
    border-radius: 100px;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
  }

  .rp-hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }

  .rp-btn {
    display: inline-flex;
    align-items: center;
    padding: 14px 24px;
    border-radius: 10px;
    font-size: 0.95rem;
    font-weight: 700;
    text-decoration: none;
    transition: opacity 0.2s, border-color 0.2s, color 0.2s;
  }

  .rp-btn-ghost {
    background: transparent;
    color: var(--text-color);
    border: 1px solid #cbd5e1;
  }

  .rp-btn-ghost:hover {
    border-color: var(--primary-color);
    color: var(--primary-color);
  }

  /* Trusted */
  .rp-trusted {
    padding: 0 24px 64px;
  }

  .rp-trusted :global(.customer-logos) {
    margin-top: 0;
    margin-bottom: 0;
  }

  /* Blocks */
  .rp-block {
    padding: clamp(72px, 10vw, 100px) 24px;
  }

  .rp-block--light {
    background: #f8fafc;
  }

  .rp-block--white {
    background: #fff;
  }

  .rp-container {
    max-width: 960px;
    margin: 0 auto;
  }

  .rp-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--primary-color);
    margin-bottom: 12px;
  }

  .rp-heading {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--text-color);
    margin: 0 0 16px;
  }

  .rp-lead {
    font-size: 1.15rem;
    line-height: 1.6;
    color: #475569;
    margin: 0 0 48px;
    max-width: 52ch;
  }

  /* Cards */
  .rp-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .rp-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 28px;
    text-align: center;
    transition: box-shadow 0.2s, border-color 0.2s;
  }

  .rp-card:hover {
    border-color: #cbd5e1;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
  }

  .rp-card-icon {
    width: 40px;
    height: 40px;
    line-height: 40px;
    margin: 0 auto 16px;
    background: var(--primary-color);
    color: #fff;
    font-size: 1rem;
    font-weight: 800;
    border-radius: 12px;
  }

  .rp-card h3 {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--text-color);
    margin: 0 0 6px;
  }

  .rp-card p {
    font-size: 0.9rem;
    color: #64748b;
    margin: 0;
    line-height: 1.4;
  }

  /* Comparison */
  .rp-compare {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 40px;
  }

  .rp-compare-col {
    border-radius: 16px;
    padding: 28px;
    border: 1px solid #e2e8f0;
  }

  .rp-compare-col--old {
    background: #f8fafc;
  }

  .rp-compare-col--new {
    background: linear-gradient(160deg, #faf5ff 0%, #f5f3ff 100%);
    border-color: var(--primary-color);
    box-shadow: 0 4px 20px rgba(139, 92, 246, 0.1);
  }

  .rp-compare-col h3 {
    font-size: 1rem;
    font-weight: 800;
    color: var(--text-color);
    margin: 0 0 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid #e2e8f0;
  }

  .rp-compare-col--new h3 {
    color: var(--primary-color);
    border-bottom-color: rgba(139, 92, 246, 0.3);
  }

  .rp-compare-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .rp-compare-col li {
    font-size: 0.95rem;
    color: #475569;
    padding: 10px 0;
    border-bottom: 1px solid #f1f5f9;
    line-height: 1.4;
  }

  .rp-compare-col li:last-child {
    border-bottom: none;
  }

  .rp-compare-col--new li {
    color: var(--text-color);
  }

  .rp-compare-col em {
    display: block;
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #64748b;
    font-style: normal;
    margin-bottom: 2px;
  }

  .rp-compare-col--new em {
    color: var(--primary-color);
  }

  /* RCA one-liner */
  .rp-rca {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 20px 24px;
    font-size: 1rem;
    line-height: 1.5;
    color: #475569;
  }

  .rp-rca strong {
    color: var(--text-color);
  }

  /* CTA */
  .rp-cta {
    background: linear-gradient(180deg, #f5f3ff 0%, #ede9fe 100%);
    padding: clamp(80px, 10vw, 100px) 24px;
    text-align: center;
  }

  .rp-cta-inner {
    max-width: 640px;
    margin: 0 auto;
  }

  .rp-cta-inner h2 {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    color: var(--text-color);
    margin: 0 0 28px;
    line-height: 1.2;
  }

  .rp-cta-btns {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .rp-hero {
      min-height: auto;
      padding-top: 60px;
      padding-bottom: 60px;
    }

    .rp-cards {
      grid-template-columns: 1fr;
    }

    .rp-compare {
      grid-template-columns: 1fr;
    }
  }
</style>
