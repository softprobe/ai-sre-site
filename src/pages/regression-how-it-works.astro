                    <rect x="525" y="105" width="80" height="28" rx="8" fill="#bbf7d0" />
                    <text x="565" y="125" text-anchor="middle" fill="#166534" font-size="14" font-weight="800">SUCCESS</text>
                    
                    <text x="370" y="155" fill="#64748b" font-size="16" font-weight="600">Service: flights-api</text>
                    <text x="370" y="185" fill="#64748b" font-size="16" font-weight="600">Duration: 45ms</text>
                  </g>

                  <!-- Layer 1: Node 2 -->
                  <g filter="url(#node-shadow)">
                    <rect x="350" y="255" width="270" height="170" rx="18" fill="#fff" />
                    <rect x="350" y="255" width="270" height="54" rx="18" fill="#7c3aed" />
                    <rect x="350" y="295" width="270" height="14" fill="#7c3aed" />
                    <text x="485" y="290" text-anchor="middle" fill="#fff" font-size="19" font-weight="800">/flights/book</text>
                    
                    <rect x="370" y="320" width="60" height="28" rx="8" fill="#f1f5f9" />
                    <text x="400" y="340" text-anchor="middle" fill="#475569" font-size="15" font-weight="800">POST</text>
                    
                    <rect x="435" y="320" width="85" height="28" rx="8" fill="#f1f5f9" />
                    <text x="477.5" y="340" text-anchor="middle" fill="#475569" font-size="14" font-weight="700">INBOUND</text>
                    
                    <rect x="525" y="320" width="80" height="28" rx="8" fill="#bbf7d0" />
                    <text x="565" y="340" text-anchor="middle" fill="#166534" font-size="14" font-weight="800">SUCCESS</text>
                    
                    <text x="370" y="370" fill="#64748b" font-size="16" font-weight="600">Service: flights-api</text>
                    <text x="370" y="400" fill="#64748b" font-size="16" font-weight="600">Duration: 120ms</text>
                  </g>

                  <!-- Layer 1: Node 3 -->
                  <g filter="url(#node-shadow)">
                    <rect x="350" y="470" width="270" height="170" rx="18" fill="#fff" />
                    <rect x="350" y="470" width="270" height="54" rx="18" fill="#7c3aed" />
                    <rect x="350" y="510" width="270" height="14" fill="#7c3aed" />
                    <text x="485" y="505" text-anchor="middle" fill="#fff" font-size="19" font-weight="800">/flights/status</text>
                    
                    <rect x="370" y="535" width="60" height="28" rx="8" fill="#f1f5f9" />
                    <text x="400" y="555" text-anchor="middle" fill="#475569" font-size="15" font-weight="800">GET</text>
                    
                    <rect x="435" y="535" width="85" height="28" rx="8" fill="#f1f5f9" />
                    <text x="477.5" y="555" text-anchor="middle" fill="#475569" font-size="14" font-weight="700">INBOUND</text>
                    
                    <rect x="525" y="535" width="80" height="28" rx="8" fill="#bbf7d0" />
                    <text x="565" y="555" text-anchor="middle" fill="#166534" font-size="14" font-weight="800">SUCCESS</text>
                    
                    <text x="370" y="585" fill="#64748b" font-size="16" font-weight="600">Service: flights-api</text>
                    <text x="370" y="615" fill="#64748b" font-size="16" font-weight="600">Duration: 15ms</text>
                  </g>

                  <!-- Layer 2: Node 1 -->
                  <g filter="url(#node-shadow)">
                    <rect x="700" y="255" width="270" height="170" rx="18" fill="#fff" stroke="#fecaca" stroke-width="2.5" />
                    <rect x="700" y="255" width="270" height="54" rx="18" fill="#7c3aed" />
                    <rect x="700" y="295" width="270" height="14" fill="#7c3aed" />
                    <text x="835" y="290" text-anchor="middle" fill="#fff" font-size="19" font-weight="800">payment-auth</text>
                    
                    <rect x="720" y="320" width="60" height="28" rx="8" fill="#f1f5f9" />
                    <text x="750" y="340" text-anchor="middle" fill="#475569" font-size="15" font-weight="800">POST</text>
                    
                    <rect x="785" y="320" width="95" height="28" rx="8" fill="#f1f5f9" />
                    <text x="832.5" y="340" text-anchor="middle" fill="#475569" font-size="14" font-weight="700">OUTBOUND</text>
                    
                    <rect x="885" y="320" width="70" height="28" rx="8" fill="#fecaca" />
