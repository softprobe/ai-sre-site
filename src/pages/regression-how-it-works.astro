---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookDemoButton from '../components/BookDemoButton.astro';
import { icons } from '../lib/icons.js';
---

<BaseLayout
  title="How Softprobe Regression Testing Works | Softprobe"
  description="Testing architecture for the AI era that perfectly replicates production, guarantees full test coverage, manages dependencies, and diagnoses flaky test results."
>
  <div class="hw-page">
    <!-- HERO -->
    <header class="hw-hero">
      <div class="section-container">
        <h1 class="hw-title">How It Works</h1>
        <p class="hw-lead">Testing architecture for the AI era that perfectly replicates production, guarantees full test coverage, manages dependencies, and diagnoses flaky test results.</p>
        <div class="hw-hero-actions">
          <BookDemoButton />
        </div>
      </div>
    </header>

    <!-- STEPS -->
    <section class="hw-steps">
      <div class="section-container">
        
        <!-- STEP 1 -->
        <div class="hw-step">
          <div class="hw-step-content">
            <h2>We Learn From Real Traffic</h2>
            <p>Manually written tests can't cover all features. Synthetic test data can't cover all scenarios. Softprobe passively observes live production requests.</p>
            <ul class="hw-check-list">
              <li>API inputs & Auth context</li>
              <li>Downstream calls & DB queries</li>
              <li>External API responses</li>
            </ul>
            <p class="hw-punch">Ensure 100% coverage of real user behavior.</p>
          </div>
          <div class="hw-step-visual">
            <div class="visual-card execution-path-visual">
              <!-- Execution path: all calls connected back to POST /checkout -->
              <svg class="execution-path-svg" viewBox="0 0 380 272" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <defs>
                  <linearGradient id="ep-line-grad" x1="0%" y1="0%" x2="0%" y2="100%">
                    <stop offset="0%" stop-color="var(--primary-color)" stop-opacity="0.5" />
                    <stop offset="100%" stop-color="var(--primary-color)" stop-opacity="0.15" />
                  </linearGradient>
                  <filter id="ep-node-shadow" x="-20%" y="-20%" width="140%" height="140%">
                    <feDropShadow dx="0" dy="2" stdDeviation="2" flood-opacity="0.08" />
                  </filter>
                </defs>

                <!-- Connection paths: root → tier1 → tier2 (smooth rounded corners) -->
                <g class="ep-connectors" stroke="url(#ep-line-grad)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <!-- Trunk: POST /checkout down to branch -->
                  <path d="M 190 52 L 190 72" />
                  <!-- Branch to Auth (left) – rounded bend -->
                  <path d="M 190 72 C 190 88 190 88 160 88 C 100 88 70 88 70 98 L 70 108" />
                  <!-- Branch to Inventory (center) -->
                  <path d="M 190 72 L 190 108" />
                  <!-- Branch to Stripe (right) – rounded bend -->
                  <path d="M 190 72 C 190 88 190 88 220 88 C 280 88 310 88 310 98 L 310 108" />
                  <!-- Inventory → Redis – rounded -->
                  <path d="M 190 152 C 190 168 190 172 170 172 C 140 172 130 172 130 188 L 130 208" />
                  <!-- Inventory → Postgres – rounded -->
                  <path d="M 190 152 C 190 168 190 172 210 172 C 240 172 250 172 250 188 L 250 208" />
                </g>

                <!-- Nodes (drawn after lines so they sit on top) -->
                <!-- Root: POST /checkout -->
                <g filter="url(#ep-node-shadow)">
                  <rect class="ep-node ep-node--root" x="130" y="12" width="120" height="40" rx="10" />
                  <text x="190" y="32" class="ep-label ep-label--root" text-anchor="middle">POST /checkout</text>
                  <text x="190" y="46" class="ep-sublabel" text-anchor="middle">200 OK</text>
                </g>

                <!-- Tier 1: Auth, Inventory, Stripe -->
                <g filter="url(#ep-node-shadow)">
                  <rect class="ep-node ep-node--t1" x="20" y="108" width="100" height="44" rx="10" />
                  <text x="70" y="130" class="ep-label" text-anchor="middle">Auth</text>
                  <text x="70" y="143" class="ep-sublabel" text-anchor="middle">JWT valid</text>
                </g>
                <g filter="url(#ep-node-shadow)">
                  <rect class="ep-node ep-node--t1 ep-node--center" x="140" y="108" width="100" height="44" rx="10" />
                  <text x="190" y="130" class="ep-label" text-anchor="middle">Inventory</text>
                  <text x="190" y="143" class="ep-sublabel" text-anchor="middle">fetch_v2</text>
                </g>
                <g filter="url(#ep-node-shadow)">
                  <rect class="ep-node ep-node--t1" x="260" y="108" width="100" height="44" rx="10" />
                  <text x="310" y="130" class="ep-label" text-anchor="middle">Stripe</text>
                  <text x="310" y="143" class="ep-sublabel" text-anchor="middle">success</text>
                </g>

                <!-- Tier 2: Redis, Postgres (under Inventory) -->
                <g filter="url(#ep-node-shadow)">
                  <rect class="ep-node ep-node--t2" x="60" y="208" width="140" height="44" rx="10" />
                  <text x="130" y="230" class="ep-label" text-anchor="middle">Redis</text>
                  <text x="130" y="243" class="ep-sublabel" text-anchor="middle">hit</text>
                </g>
                <g filter="url(#ep-node-shadow)">
                  <rect class="ep-node ep-node--t2" x="180" y="208" width="140" height="44" rx="10" />
                  <text x="250" y="230" class="ep-label" text-anchor="middle">Postgres</text>
                  <text x="250" y="243" class="ep-sublabel" text-anchor="middle">query</text>
                </g>
              </svg>
            </div>
          </div>
        </div>

        <!-- STEP 2 -->
        <div class="hw-step reverse">
          <div class="hw-step-content">
            <h2>We Capture the Full Execution State</h2>
            <p>Flaky tests aren’t flaky. They’re missing context.</p>
            <p>We snapshot the entire runtime environment so every test case becomes deterministic and reproducible.</p>
            <ul class="hw-check-list">
              <li>Dependency responses & database result sets</li>
              <li>Feature flags & environment configuration</li>
              <li>Time-based inputs</li>
              <li>External API interactions</li>
            </ul>
            <p class="hw-punch">All failures are reproducible.</p>
          </div>
          <div class="hw-step-visual">
            <div class="visual-card">
              <!-- NEW Execution State Visual (Code Replay Style) -->
              <div class="execution-state-visual">
                <div class="code-window">
                  <div class="code-header">
                    <div class="code-dots"><span></span><span></span><span></span></div>
                    <span>runtime_context_preserved.json</span>
                  </div>
                  <div class="code-body">
                    <div class="code-line"><span class="code-num">1</span> <span class="code-key">"status"</span>: <span class="code-str">"SNAPSHOT_CAPTURED"</span>,</div>
                    <div class="code-line code-line--highlight"><span class="code-num">2</span> <span class="code-key">"snapshots"</span>: &#123; <span class="code-val">"db_seq"</span>: <span class="code-num-val">442</span>, <span class="code-val">"clock"</span>: <span class="code-str">"10:29:39.1"</span> &#125;,</div>
                    <div class="code-line"><span class="code-num">3</span> <span class="code-key">"flags"</span>: &#123; <span class="code-val">"new_ui"</span>: <span class="code-str">"canary"</span>, <span class="code-val">"beta"</span>: <span class="code-bool">true</span> &#125;,</div>
                    <div class="code-line"><span class="code-num">4</span> <span class="code-key">"context"</span>: &#123; <span class="code-val">"seed"</span>: <span class="code-str">"0x8fa2"</span>, <span class="code-val">"ver"</span>: <span class="code-str">"v1.4.2"</span> &#125;</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- STEP 3 -->
        <div class="hw-step">
          <div class="hw-step-content">
            <h2>We Generate Millions of Tests Automatically</h2>
            <p>We don't generate test code. We generate executable replays from real traffic. No writing tests. No maintaining mocks. No brittle fixtures.</p>
            <ul class="hw-check-list">
              <li>Parameterized regression cases</li>
              <li>Injected dependencies</li>
              <li>Mirrored environment</li>
            </ul>
            <p class="hw-punch">Every request becomes a permanent test. Instantly.</p>
          </div>
          <div class="hw-step-visual">
            <div class="visual-card visual-card--volume">
              <!-- Test Suite Generation: volume + counter -->
              <div class="test-volume-visual">
                <div class="volume-frame">
                  <div class="volume-container">
                    <div class="test-item" style="--i:1"><span class="test-id">#412,021</span><span class="test-dot test-dot--ok"></span></div>
                    <div class="test-item" style="--i:2"><span class="test-id">#412,022</span><span class="test-dot test-dot--ok"></span></div>
                    <div class="test-item" style="--i:3"><span class="test-id">#412,023</span><span class="test-dot test-dot--ok"></span></div>
                    <div class="test-item" style="--i:4"><span class="test-id">#412,024</span><span class="test-dot test-dot--ok"></span></div>
                    <div class="test-item" style="--i:5"><span class="test-id">#412,025</span><span class="test-dot test-dot--ok"></span></div>
                    <div class="test-item" style="--i:6"><span class="test-id">#412,026</span><span class="test-dot test-dot--ok"></span></div>
                    <div class="test-item" style="--i:7"><span class="test-id">#412,027</span><span class="test-dot test-dot--ok"></span></div>
                    <div class="test-item" style="--i:8"><span class="test-id">#412,028</span><span class="test-dot test-dot--ok"></span></div>
                    <div class="test-item" style="--i:9"><span class="test-id">#412,029</span><span class="test-dot test-dot--ok"></span></div>
                    <div class="test-item" style="--i:10"><span class="test-id">#412,030</span><span class="test-dot test-dot--ok"></span></div>
                  </div>
                </div>
                <div class="volume-counter">
                  <span class="counter-label">Tests generated</span>
                  <span class="counter-number">1,248,392</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- STEP 4 -->
        <div class="hw-step reverse">
          <div class="hw-step-content">
            <h2>We Replay Against Your New Version</h2>
            <p>When you ship new code, we compare the output of the Old version vs. the New version. If behavior changes unexpectedly, we catch it before users see it.</p>
            <ul class="hw-check-list">
              <li>JSON Responses & Structure</li>
              <li>Side effects (DB writes, events)</li>
              <li>Schema changes</li>
            </ul>
            <p class="hw-punch">Zero production risk. Faster releases.</p>
          </div>
          <div class="hw-step-visual">
            <div class="visual-card">
              <!-- IMPROVED Side-by-Side Replay: Nested Discrepancy -->
              <div class="replay-compare-v2">
                <div class="compare-pane">
                  <div class="pane-header">Current Version</div>
                  <div class="pane-body">
                    <div class="pane-node">
                       <div class="node-label">Inventory Service</div>
                       <div class="node-content">
                          <span class="json-key">"stock"</span>: <span class="json-val">42</span>
                       </div>
                    </div>
                  </div>
                </div>
                <div class="compare-divider">VS</div>
                <div class="compare-pane compare-pane--error">
                  <div class="pane-header">New Version</div>
                  <div class="pane-body">
                    <div class="pane-node pane-node--error">
                       <div class="node-label">Inventory Service</div>
                       <div class="node-content">
                          <span class="json-key">"stock"</span>: <span class="json-val json-val--mismatch">null</span>
                       </div>
                       <div class="node-badge">Mismatch</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- STEP 5 -->
        <div class="hw-step">
          <div class="hw-step-content">
            <h2>See the Exact Cause of Test Failures</h2>
            <p>Our session graph architecture retraces errors & behavior changes to the exact point of failure.</p>
            <ul class="hw-check-list">
              <li>Visualize preserved states and execution paths</li>
              <li>Replay full API requests and response bodies</li>
              <li>Trace the regression to the exact breaking change</li>
            </ul>
            <p class="hw-punch">Every failure is traceable to its exact cause.</p>
          </div>
          <div class="hw-step-visual">
            <div class="visual-card">
              <!-- Causal Map Visual -->
              <div class="causal-map">
                <div class="causal-step causal-step--success">
                  <div class="causal-icon" set:html={icons.CheckCircle2}></div>
                  <div class="causal-info">
                    <strong>Auth Layer</strong>
                    <span>Validated user #882</span>
                  </div>
                </div>
                <div class="causal-connector"></div>
                <div class="causal-step causal-step--success">
                  <div class="causal-icon" set:html={icons.CheckCircle2}></div>
                  <div class="causal-info">
                    <strong>Business Logic</strong>
                    <span>Applied discount "WINTER10"</span>
                  </div>
                </div>
                <div class="causal-connector"></div>
                <div class="causal-step causal-step--fail">
                  <div class="causal-icon" set:html={icons.AlertCircle}></div>
                  <div class="causal-info">
                    <strong>Tax Service</strong>
                    <span>Unexpected schema change in <code>tax_rate</code> field</span>
                  </div>
                  <div class="causal-badge">Root Cause</div>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="cta-section">
      <div class="section-container">
        <div class="cta-card">
          <h2 class="cta-title">Deploy with absolute confidence</h2>
          <div class="cta-actions">
            <BookDemoButton />
            <a href="/contact" class="btn btn-secondary">Talk to an expert</a>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .hw-hero { padding-top: 120px; padding-bottom: 40px; text-align: center; background: #fff; }
  .hw-title { font-size: clamp(2.5rem, 5vw, 4rem); margin-bottom: 24px; }
  .hw-lead { font-size: 1.25rem; color: var(--text-muted); max-width: 800px; margin: 0 auto 40px; }
  .hw-hero-actions { display: flex; justify-content: center; }

  .hw-steps { padding: 32px 0; }
  .hw-step { 
    display: grid; 
    grid-template-columns: repeat(2, minmax(0, 1fr)); 
    gap: 40px; 
    align-items: center; 
    margin-bottom: 48px; 
    width: 100%;
  }
  .hw-step > * { min-width: 0; }
  .hw-step.reverse { direction: rtl; }
  .hw-step.reverse > * { direction: ltr; }

  .hw-step h2 { font-size: 2.25rem; margin-bottom: 24px; color: var(--text-color); }
  .hw-step p { font-size: 1.1rem; margin-bottom: 24px; }
  .hw-check-list { list-style: none; padding: 0; margin-bottom: 32px; display: grid; gap: 12px; }
  .hw-check-list li { display: flex; align-items: center; gap: 10px; font-weight: 600; color: var(--text-color); }
  .hw-check-list li::before { content: "→"; color: var(--primary-color); font-weight: 900; }
  .hw-punch { font-weight: 800 !important; color: var(--text-color) !important; border-left: 4px solid var(--primary-color); padding-left: 20px; }

  .hw-step-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .visual-card { 
    background: transparent; 
    border: none; 
    padding: 24px; 
    aspect-ratio: 1;
    width: 100%;
    max-width: 520px;
    min-height: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    overflow: hidden;
    box-sizing: border-box;
  }

  /* --- Visual 1: Execution path (all calls → POST /checkout) --- */
  .execution-path-visual {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
  }
  .execution-path-svg {
    width: 100%;
    max-width: 420px;
    height: auto;
    display: block;
  }
  .execution-path-svg .ep-node {
    fill: #fff;
    stroke: #e2e8f0;
    stroke-width: 1.5;
  }
  .execution-path-svg .ep-node--root {
    fill: #f5f3ff;
    stroke: var(--primary-color);
    stroke-width: 2;
  }
  .execution-path-svg .ep-node--t1 {
    fill: #f8fafc;
  }
  .execution-path-svg .ep-node--t1.ep-node--center {
    fill: #f1f5f9;
  }
  .execution-path-svg .ep-node--t2 {
    fill: #fff;
  }
  .execution-path-svg .ep-connectors {
    stroke-linejoin: round;
  }
  .execution-path-svg .ep-label {
    font-size: 11px;
    font-weight: 700;
    fill: var(--text-color);
    font-family: var(--font-sans), sans-serif;
  }
  .execution-path-svg .ep-label--root {
    font-size: 12px;
    fill: var(--primary-color);
  }
  .execution-path-svg .ep-sublabel {
    font-size: 9px;
    fill: #64748b;
    font-family: ui-monospace, 'JetBrains Mono', monospace;
  }

  /* --- Visual 2 & 3: Code/Execution Windows --- */
  .code-window {
    background: #0f172a;
    border-radius: 12px;
    color: #f8fafc;
    font-family: 'JetBrains Mono', monospace;
    overflow: hidden;
    width: 100%;
    text-align: left;
    transform: scale(0.9);
  }
  .code-header { background: #1e293b; padding: 10px 16px; display: flex; align-items: center; gap: 12px; font-size: 0.7rem; color: #94a3b8; }
  .code-dots { display: flex; gap: 6px; }
  .code-dots span { width: 8px; height: 8px; border-radius: 50%; background: #334155; }
  .code-body { padding: 16px; font-size: 0.8rem; line-height: 1.6; }
  .code-line { display: flex; gap: 16px; }
  .code-num { color: #334155; width: 12px; text-align: right; }
  .code-key { color: #7dd3fc; }
  .code-val { color: #f472b6; }
  .code-str { color: #34d399; }
  .code-num-val { color: #fbbf24; }
  .code-bool { color: #818cf8; }
  .code-line--highlight { background: rgba(125, 211, 252, 0.1); border-left: 3px solid #7dd3fc; margin-left: -16px; padding-left: 13px; }

  /* --- Visual 3: Test Volume (Generate Millions) --- */
  .visual-card--volume {
    max-width: 560px;
    aspect-ratio: auto;
    min-height: 320px;
  }
  .test-volume-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    width: 100%;
  }
  .volume-frame {
    width: 100%;
    max-width: 340px;
    border-radius: 16px;
    background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
    border: 1px solid #e2e8f0;
    box-shadow: 0 4px 24px rgba(15, 23, 42, 0.06), inset 0 1px 0 rgba(255, 255, 255, 0.8);
    padding: 20px 24px;
  }
  .volume-container {
    position: relative;
    height: 220px;
    width: 100%;
    overflow: hidden;
    mask-image: linear-gradient(to bottom, transparent 0%, #000 15%, #000 85%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 15%, #000 85%, transparent 100%);
  }
  .test-item {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    background: #fff;
    border: 1px solid #e2e8f0;
    padding: 12px 20px;
    border-radius: 12px;
    font-size: 0.9rem;
    font-weight: 700;
    color: #334155;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    width: 100%;
    max-width: 260px;
    box-shadow: 0 2px 8px rgba(15, 23, 42, 0.06);
    animation: scrollTests 4s ease-in-out infinite;
    animation-delay: calc(var(--i) * -0.35s);
  }
  .test-id {
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
  }
  .test-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .test-dot--ok {
    background: #22c55e;
    box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.25);
  }
  @keyframes scrollTests {
    0% { top: 240px; opacity: 0; }
    8% { opacity: 1; }
    92% { opacity: 1; }
    100% { top: -50px; opacity: 0; }
  }
  .volume-counter {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 16px 28px;
    background: linear-gradient(135deg, #f5f3ff 0%, #ede9fe 100%);
    border: 1px solid #e9e5ff;
    border-radius: 14px;
    min-width: 200px;
  }
  .volume-counter .counter-label {
    font-size: 0.7rem;
    font-weight: 800;
    color: var(--primary-color);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .volume-counter .counter-number {
    font-size: 2rem;
    font-weight: 900;
    color: var(--text-color);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
  }

  /* --- Visual 4: Replay Compare v2 --- */
  .replay-compare-v2 {
    display: flex;
    align-items: center;
    gap: 16px;
    width: 100%;
    padding: 0 10px;
  }
  .compare-pane {
    flex: 1;
    background: #f8fafc;
    border: 1px solid var(--box-border);
    border-radius: 12px;
    overflow: hidden;
    text-align: left;
  }
  .compare-pane--error { border-color: #fecaca; background: #fffafb; }
  .pane-header { background: #fff; border-bottom: 1px solid #e2e8f0; padding: 8px 12px; font-size: 0.7rem; font-weight: 800; color: #94a3b8; text-transform: uppercase; }
  .compare-pane--error .pane-header { color: #ef4444; border-bottom-color: #fecaca; }
  .pane-body { padding: 16px; }
  .pane-node { padding: 10px; background: #fff; border: 1.5px solid #e2e8f0; border-radius: 8px; position: relative; }
  .pane-node--error { border-color: #ef4444; box-shadow: 0 0 12px rgba(239, 68, 68, 0.1); }
  .node-label { font-size: 0.75rem; font-weight: 800; color: var(--text-color); margin-bottom: 4px; }
  .node-content { font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; }
  .json-key { color: #64748b; }
  .json-val { color: #22c55e; font-weight: 700; }
  .json-val--mismatch { color: #ef4444; text-decoration: underline; }
  .node-badge { position: absolute; top: -10px; right: 10px; background: #ef4444; color: #fff; font-size: 0.6rem; font-weight: 800; padding: 2px 6px; border-radius: 4px; text-transform: uppercase; }
  .compare-divider { font-size: 0.8rem; font-weight: 900; color: #cbd5e1; }

  /* --- Visual 5: Causal Map --- */
  .causal-map { display: flex; flex-direction: column; width: 100%; max-width: 320px; transform: scale(0.85); margin: 0 auto; }
  .causal-step { display: flex; align-items: center; gap: 12px; padding: 12px; border-radius: 12px; border: 1.5px solid #e2e8f0; position: relative; background: #fff; text-align: left; }
  .causal-step--success { border-color: #bbf7d0; background: #f0fdf4; }
  .causal-step--fail { border-color: #fecaca; background: #fef2f2; }
  .causal-icon { width: 20px; height: 20px; flex-shrink: 0; }
