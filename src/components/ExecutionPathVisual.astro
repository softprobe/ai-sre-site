---
// ExecutionPathVisual.astro
const { variant = 'hero' } = Astro.props;
const isHero = variant === 'hero';
---

<div class={`execution-visual ${variant}`}>
  <div class="visual-container">
    <svg class="visual-svg" viewBox="0 0 800 400" preserveAspectRatio="xMidYMid meet">
      <!-- ... (the rest of the SVG) ... -->
      <defs>
        <marker id="arrowhead" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
          <polygon points="0 0, 10 3.5, 0 7" fill="var(--primary-color)" />
        </marker>
        <linearGradient id="line-grad" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="var(--primary-color)" stop-opacity="0.2" />
          <stop offset="100%" stop-color="var(--primary-color)" stop-opacity="1" />
        </linearGradient>
      </defs>

      <!-- Connections (Lines) -->
      <g class="lines">
        <!-- User to Main API -->
        <path d="M 50 200 L 180 200" class="flow-line active" marker-end="url(#arrowhead)" />
        
        <!-- Main API to Auth -->
        <path d="M 250 170 L 380 80" class="flow-line" marker-end="url(#arrowhead)" />
        
        <!-- Main API to DB -->
        <path d="M 280 200 L 380 200" class="flow-line" marker-end="url(#arrowhead)" />
        
        <!-- Main API to Inventory -->
        <path d="M 250 230 L 380 320" class="flow-line" marker-end="url(#arrowhead)" />
        
        <!-- Inventory to Stripe (External) -->
        <path d="M 480 320 L 610 320" class="flow-line" marker-end="url(#arrowhead)" id="line-inventory-stripe" />
      </g>

      <!-- Flow Particles -->
      <g class="particles">
        <circle r="4" class="flow-particle"><animateMotion dur="2.5s" repeatCount="indefinite" path="M 50 200 L 180 200" /></circle>
        <circle r="3" class="flow-particle"><animateMotion dur="3s" repeatCount="indefinite" path="M 250 170 L 380 80" /></circle>
        <circle r="3" class="flow-particle"><animateMotion dur="2.8s" repeatCount="indefinite" path="M 280 200 L 380 200" /></circle>
        <circle r="3" class="flow-particle"><animateMotion dur="3.2s" repeatCount="indefinite" path="M 250 230 L 380 320" /></circle>
        <circle r="3" class="flow-particle"><animateMotion dur="3.5s" repeatCount="indefinite" path="M 480 320 L 610 320" /></circle>
      </g>

      <!-- Path Labels -->
      <g class="path-labels">
        <text x="115" y="190" text-anchor="middle" class="line-label">POST /order</text>
        <text x="315" y="115" text-anchor="middle" class="line-label" transform="rotate(-35, 315, 115)">GET /session</text>
        <text x="330" y="195" text-anchor="middle" class="line-label">SELECT</text>
        <text x="315" y="285" text-anchor="middle" class="line-label" transform="rotate(35, 315, 285)">GET /stock</text>
        <text x="545" y="315" text-anchor="middle" class="line-label">POST /pay</text>
      </g>

      <!-- Nodes -->
      <g class="nodes">
        <!-- User -->
        <g transform="translate(10, 180)">
          <rect width="80" height="40" rx="4" class="node-box user-node" />
          <text x="40" y="25" text-anchor="middle" class="node-label">User</text>
        </g>

        <!-- Main API Service -->
        <g transform="translate(180, 160)">
          <rect width="120" height="80" rx="8" class="node-box main-node" />
          <text x="60" y="35" text-anchor="middle" class="node-title">Checkout</text>
          <text x="60" y="55" text-anchor="middle" class="node-subtitle">Service</text>
          <circle cx="10" cy="10" r="4" class="status-dot" />
        </g>

        <!-- Auth Service -->
        <g transform="translate(380, 40)">
          <rect width="100" height="60" rx="6" class="node-box tool-node" />
          <text x="50" y="35" text-anchor="middle" class="node-title">Auth</text>
          <text x="50" y="50" text-anchor="middle" class="node-api">GET /session</text>
        </g>

        <!-- Database -->
        <g transform="translate(380, 170)">
          <rect width="100" height="60" rx="6" class="node-box tool-node" />
          <text x="50" y="35" text-anchor="middle" class="node-title">Postgres</text>
          <text x="50" y="50" text-anchor="middle" class="node-api">SELECT *</text>
        </g>

        <!-- Inventory -->
        <g transform="translate(380, 290)">
          <rect width="100" height="60" rx="6" class="node-box tool-node" />
          <text x="50" y="35" text-anchor="middle" class="node-title">Inventory</text>
          <text x="50" y="50" text-anchor="middle" class="node-api">GET /stock</text>
        </g>

        <!-- Stripe External -->
        <g transform="translate(610, 290)">
          <rect width="100" height="60" rx="6" class="node-box external-node" />
          <text x="50" y="35" text-anchor="middle" class="node-title">Stripe</text>
          <text x="50" y="50" text-anchor="middle" class="node-api">POST /pay</text>
        </g>
      </g>

      <!-- Softprobe Observation Overlay -->
      <rect x="160" y="20" width="350" height="360" rx="12" class="observation-ring" />
      <text x="335" y="370" text-anchor="middle" class="observation-label">{isHero ? 'Softprobe captures full call graph' : 'Live Capture'}</text>
    </svg>
  </div>
</div>

<style>
  .execution-visual {
    width: 100%;
    background: #ffffff;
    border-radius: 12px;
    padding: 20px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    overflow: hidden;
  }

  .execution-visual.small {
    padding: 12px;
    box-shadow: none;
    background: transparent;
    border: none;
  }

  /* ... rest of styles ... */

  .visual-container {
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
  }

  .visual-svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .flow-line {
    fill: none;
    stroke: #e2e8f0;
    stroke-width: 2;
    stroke-dasharray: 4 4;
  }

  .flow-line.active {
    stroke: var(--primary-color);
    stroke-dasharray: none;
    animation: flowPulse 2s infinite;
  }

  .flow-particle {
    fill: var(--primary-color);
    filter: drop-shadow(0 0 4px var(--primary-color));
  }

  @keyframes flowPulse {
    0% { stroke-opacity: 0.3; stroke-width: 2; }
    50% { stroke-opacity: 1; stroke-width: 3; }
    100% { stroke-opacity: 0.3; stroke-width: 2; }
  }

  .node-box {
    fill: #f8fafc;
    stroke: #e2e8f0;
    stroke-width: 1;
  }

  .main-node {
    fill: #f5f3ff;
    stroke: #ddd6fe;
    stroke-width: 2;
  }

  .tool-node {
    fill: #ffffff;
    stroke: #e2e8f0;
  }

  .external-node {
    fill: #fff7ed;
    stroke: #fed7aa;
  }

  .user-node {
    fill: #f1f5f9;
  }

  .node-title {
    font-size: 14px;
    font-weight: 700;
    fill: var(--text-color);
  }

  .node-subtitle {
    font-size: 11px;
    fill: #64748b;
  }

  .node-api {
    font-size: 10px;
    font-family: monospace;
    fill: var(--primary-color);
  }

  .node-label {
    font-size: 12px;
    font-weight: 600;
    fill: #475569;
  }

  .line-label {
    font-size: 10px;
    font-weight: 700;
    fill: #94a3b8;
    font-family: monospace;
    pointer-events: none;
  }

  .status-dot {
    fill: #22c55e;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { r: 3; opacity: 1; }
    50% { r: 5; opacity: 0.5; }
    100% { r: 3; opacity: 1; }
  }

  .observation-ring {
    fill: none;
    stroke: var(--primary-color);
    stroke-width: 2;
    stroke-dasharray: 8 4;
    opacity: 0.2;
    animation: dashOffset 20s linear infinite;
  }

  @keyframes dashOffset {
    from { stroke-dashoffset: 0; }
    to { stroke-dashoffset: 100; }
  }

  .observation-label {
    font-size: 12px;
    font-weight: 700;
    fill: var(--primary-color);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>
