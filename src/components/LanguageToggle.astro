---
// LanguageToggle.astro
// Renders a compact EN / 中文 pill toggle that switches at runtime via JS.
// No server-side language detection is needed for a static site — we read
// navigator.language in the client script and hydrate accordingly.
---

<div class="lang-toggle" id="lang-toggle" aria-label="Language selector">
  <button
    id="lang-btn-en"
    class="lang-btn lang-btn--active"
    data-lang="en"
    aria-label="Switch to English"
    type="button"
  >EN</button>
  <span class="lang-divider" aria-hidden="true">|</span>
  <button
    id="lang-btn-zh"
    class="lang-btn"
    data-lang="zh"
    aria-label="切换至简体中文"
    type="button"
  >中文</button>
</div>

<style>
  .lang-toggle {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    background: rgba(139, 92, 246, 0.08);
    border: 1px solid rgba(139, 92, 246, 0.2);
    border-radius: 999px;
    padding: 3px 10px;
    user-select: none;
  }

  .lang-btn {
    background: none;
    border: none;
    padding: 2px 5px;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    cursor: pointer;
    color: var(--text-muted, #475569);
    transition: color 0.18s ease, background 0.18s ease;
    line-height: 1;
  }

  .lang-btn:hover {
    color: var(--primary-color, #8b5cf6);
  }

  .lang-btn--active {
    color: var(--primary-color, #8b5cf6);
    background: rgba(139, 92, 246, 0.12);
  }

  .lang-divider {
    color: rgba(139, 92, 246, 0.3);
    font-size: 0.7rem;
    line-height: 1;
    pointer-events: none;
  }
</style>

<script>
  import type { Locale } from '../i18n/translations';
  import { translations, supportedLocales, defaultLocale } from '../i18n/translations';

  // ─── Helpers ────────────────────────────────────────────────────────────────

  const STORAGE_KEY = 'sp-locale';

  /** Detect the best locale from browser prefs, falling back to 'en'. */
  function detectLocale(): Locale {
    // 1. User previously picked a language
    const stored = localStorage.getItem(STORAGE_KEY) as Locale | null;
    if (stored && supportedLocales.includes(stored)) return stored;

    // 2. Browser language preference
    const langs = navigator.languages?.length ? navigator.languages : [navigator.language];
    for (const lang of langs) {
      const code = lang.split('-')[0].toLowerCase() as Locale;
      if (supportedLocales.includes(code)) return code;
    }

    return defaultLocale;
  }

  /** Apply translations to all [data-i18n] elements on the page. */
  function applyLocale(locale: Locale): void {
    const dict = translations[locale] ?? translations[defaultLocale];

    document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
      const key = el.dataset.i18n!;
      if (key in dict) el.textContent = dict[key];
    });

    // Update html lang attribute for accessibility / SEO
    document.documentElement.lang = locale === 'zh' ? 'zh-CN' : 'en';

    // Sync toggle button states
    document.querySelectorAll<HTMLButtonElement>('.lang-btn').forEach((btn) => {
      btn.classList.toggle('lang-btn--active', btn.dataset.lang === locale);
    });
  }

  // ─── Boot ───────────────────────────────────────────────────────────────────

  let currentLocale: Locale = detectLocale();

  // Initial render — wait for DOM to be ready
  document.addEventListener('DOMContentLoaded', () => {
    applyLocale(currentLocale);

    // Wire up toggle buttons
    document.querySelectorAll<HTMLButtonElement>('.lang-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const lang = btn.dataset.lang as Locale;
        if (!lang || lang === currentLocale) return;
        currentLocale = lang;
        localStorage.setItem(STORAGE_KEY, lang);
        applyLocale(lang);
      });
    });
  });
</script>
