---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer-inner">
    <div class="site-footer-grid">
      <!-- Brand column -->
      <div class="site-footer-brand">
        <a href="/" class="site-footer-logo" aria-label="Softprobe Home">
          <img src="/logos/4.svg" alt="Softprobe" width="28" height="28" />
          <span>Softprobe</span>
        </a>
        <p class="site-footer-tagline" data-i18n="footer.tagline">Deploy with Absolute Confidence.</p>
      </div>

      <!-- Product -->
      <div class="site-footer-col">
        <h4 data-i18n="footer.product">Product</h4>
        <ul>
          <li><a href="/regression-how-it-works" data-i18n="footer.howItWorks">How it Works</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div class="site-footer-col">
        <h4 data-i18n="footer.resources">Resources</h4>
        <ul>
          <li><a href="/integrations" data-i18n="footer.integrations">Integrations</a></li>
          <li><a href="/blog" data-i18n="footer.blog">Blog</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div class="site-footer-col">
        <h4 data-i18n="footer.company">Company</h4>
        <ul>
          <li><a href="/contact" data-i18n="footer.contact">Contact</a></li>
        </ul>
      </div>
    </div>

    <div class="site-footer-bottom">
      <p>&copy; {currentYear} Softprobe. <span data-i18n="footer.rights">All rights reserved.</span></p>
    </div>
  </div>
</footer>
