---
// RegressionCompareVisual.astro
---

<div class="compare-visual">
  <div class="compare-header">
    <div class="version">v1.2.0 (Prod)</div>
    <div class="vs">vs</div>
    <div class="version">v1.3.0 (Staging)</div>
  </div>
  
  <div class="compare-body">
    <div class="json-pane">
      <div class="json-line">
        <span class="json-key">"status"</span>: <span class="json-val">"success"</span>
      </div>
      <div class="json-line">
        <span class="json-key">"order_id"</span>: <span class="json-val">"ord_991"</span>
      </div>
      <div class="json-line">
        <span class="json-key">"amount"</span>: <span class="json-val">29.99</span>
      </div>
    </div>
    
    <div class="divider"></div>
    
    <div class="json-pane">
      <div class="json-line">
        <span class="json-key">"status"</span>: <span class="json-val">"success"</span>
      </div>
      <div class="json-line diff-remove">
        <span class="json-key">"order_id"</span>: <span class="json-val">"ord_991"</span>
      </div>
      <div class="json-line diff-add">
        <span class="json-key">"transaction_id"</span>: <span class="json-val">"tx_abc"</span>
      </div>
      <div class="json-line">
        <span class="json-key">"amount"</span>: <span class="json-val">29.99</span>
      </div>
    </div>
  </div>
  
  <div class="alert">
    <div class="alert-icon">⚠️</div>
    <div class="alert-text">Schema Regression Detected: Field <code>order_id</code> missing in v1.3.0</div>
  </div>
</div>

<style>
  .compare-visual {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 20px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.02);
  }

  .compare-header {
    display: flex;
    justify-content: space-around;
    align-items: center;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid #f1f5f9;
  }

  .version {
    font-size: 11px;
    font-weight: 700;
    color: #64748b;
    text-transform: uppercase;
  }

  .vs {
    font-size: 10px;
    font-weight: 800;
    color: #94a3b8;
    background: #f8fafc;
    padding: 4px 8px;
    border-radius: 999px;
  }

  .compare-body {
    display: flex;
    gap: 20px;
    margin-bottom: 16px;
  }

  .json-pane {
    flex: 1;
    font-family: monospace;
    font-size: 11px;
    padding: 12px;
    background: #f8fafc;
    border-radius: 6px;
  }

  .divider {
    width: 1px;
    background: #e2e8f0;
  }

  .json-line {
    margin-bottom: 4px;
    padding: 2px 4px;
    border-radius: 2px;
    white-space: pre-wrap;
    word-break: break-all;
  }

  .json-key { color: #8b5cf6; }
  .json-val { color: #0ea5e9; }

  .diff-remove {
    background: #fee2e2;
    color: #b91c1c;
    text-decoration: line-through;
  }

  .diff-add {
    background: #dcfce7;
    color: #15803d;
  }

  .alert {
    display: flex;
    gap: 12px;
    padding: 12px;
    background: #fffbeb;
    border: 1px solid #fef3c7;
    border-radius: 6px;
    align-items: center;
  }

  .alert-icon { font-size: 16px; }
  .alert-text {
    font-size: 11px;
    font-weight: 600;
    color: #92400e;
  }

  .alert-text code {
    background: rgba(255,255,255,0.5);
    padding: 1px 4px;
    border-radius: 4px;
  }
</style>
